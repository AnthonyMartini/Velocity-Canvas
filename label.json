{
  "type": "Label",
  "control": "Label@2.1.0",
  "defaults": {
    "text": "Label",
    "x": 100,
    "y": 100,
    "width": 200,
    "height": 32,
    "color": "#201f1e",
    "fill": "transparent",
    "fontSize": 14,
    "fontWeight": "FontWeight.Normal",
    "align": "Align.Left",
    "verticalAlign": "VerticalAlign.Middle",
    "italic": false,
    "underline": false,
    "visible": true,
    "overflow": "hidden",
    "lineHeight": 1.5,
    "paddingLeft": 8,
    "paddingRight": 8,
    "paddingTop": 4,
    "paddingBottom": 4
  },
  "properties": [
    { "key": "text",          "label": "Text",           "type": "text" },
    { "key": "x",            "label": "X",              "type": "number" },
    { "key": "y",            "label": "Y",              "type": "number" },
    { "key": "width",        "label": "Width",          "type": "number" },
    { "key": "height",       "label": "Height",         "type": "number" },
    { "key": "color",        "label": "Text Color",     "type": "color" },
    { "key": "fill",         "label": "Fill",           "type": "color" },
    { "key": "fontSize",     "label": "Font Size",      "type": "number" },
    { "key": "fontWeight",   "label": "Font Weight",    "type": "select", "options": ["FontWeight.Lighter", "FontWeight.Normal", "FontWeight.Semibold", "FontWeight.Bold"] },
    { "key": "align",        "label": "Text Align",     "type": "select", "options": ["Align.Left", "Align.Center", "Align.Right", "Align.Justify"] },
    { "key": "verticalAlign","label": "Vertical Align", "type": "select", "options": ["VerticalAlign.Top", "VerticalAlign.Middle", "VerticalAlign.Bottom"] },
    { "key": "italic",       "label": "Italic",         "type": "boolean" },
    { "key": "underline",    "label": "Underline",      "type": "boolean" },
    { "key": "visible",      "label": "Visible",        "type": "boolean" },
    { "key": "paddingLeft",  "label": "Padding Left",   "type": "number" },
    { "key": "paddingRight", "label": "Padding Right",  "type": "number" },
    { "key": "paddingTop",   "label": "Padding Top",    "type": "number" },
    { "key": "paddingBottom","label": "Padding Bottom", "type": "number" }
  ]
}