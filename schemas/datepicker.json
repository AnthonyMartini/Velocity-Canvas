{
  "type": "DatePicker",
  "control": "Classic/DatePicker@2.2.0",
  "defaults": {
    "DefaultDate": "",
    "Format": "ShortDate",
    "Language": "en-US",
    "x": 40,
    "y": 40,
    "width": 200,
    "height": 40,
    "color": "#323130",
    "fill": "#ffffff",
    "fontSize": 13,
    "fontWeight": "FontWeight.Normal",
    "borderColor": "#8a8886",
    "borderStyle": "BorderStyle.Solid",
    "borderThickness": 1,
    "focusedBorderColor": "#0078d4",
    "focusedBorderThickness": 2,
    "hoverBorderColor": "#323130",
    "iconFill": "#605e5c",
    "iconBackground": "transparent",
    "isEditable": false,
    "visible": true,
    "disabled": false,
    "startYear": 1970,
    "endYear": 2050
  },
  "properties": [
    { "key": "DefaultDate",          "label": "Default Date",           "type": "text" },
    { "key": "SelectedDate",         "label": "Selected Date",          "type": "text" },
    { "key": "Format",               "label": "Format",                 "type": "text" },
    { "key": "Language",             "label": "Language",               "type": "text" },
    { "key": "x",                    "label": "X",                      "type": "number" },
    { "key": "y",                    "label": "Y",                      "type": "number" },
    { "key": "width",                "label": "Width",                  "type": "number" },
    { "key": "height",               "label": "Height",                 "type": "number" },
    { "key": "color",                "label": "Text Color",             "type": "color" },
    { "key": "fill",                 "label": "Fill",                   "type": "color" },
    { "key": "fontSize",             "label": "Font Size",              "type": "number" },
    { "key": "fontWeight",           "label": "Font Weight",            "type": "select",
      "options": ["FontWeight.Lighter","FontWeight.Normal","FontWeight.Semibold","FontWeight.Bold"] },
    { "key": "italic",               "label": "Italic",                 "type": "boolean" },
    { "key": "paddingLeft",          "label": "Padding Left",           "type": "number" },
    { "key": "paddingRight",         "label": "Padding Right",          "type": "number" },
    { "key": "paddingTop",           "label": "Padding Top",            "type": "number" },
    { "key": "paddingBottom",        "label": "Padding Bottom",         "type": "number" },
    { "key": "borderColor",          "label": "Border Color",           "type": "color" },
    { "key": "borderStyle",          "label": "Border Style",           "type": "select",
      "options": ["BorderStyle.None","BorderStyle.Solid","BorderStyle.Dashed","BorderStyle.Dotted"] },
    { "key": "borderThickness",      "label": "Border Thickness",       "type": "number" },
    { "key": "focusedBorderColor",   "label": "Focused Border Color",   "type": "color" },
    { "key": "focusedBorderThickness","label": "Focused Border Width",  "type": "number" },
    { "key": "hoverBorderColor",     "label": "Hover Border Color",     "type": "color" },
    { "key": "disabledBorderColor",  "label": "Disabled Border Color",  "type": "color" },
    { "key": "disabledColor",        "label": "Disabled Text Color",    "type": "color" },
    { "key": "disabledFill",         "label": "Disabled Fill",          "type": "color" },
    { "key": "iconFill",             "label": "Icon Color",             "type": "color" },
    { "key": "iconBackground",       "label": "Icon Background",        "type": "color" },
    { "key": "inputTextPlaceholder", "label": "Placeholder",            "type": "text" },
    { "key": "isEditable",           "label": "Is Editable",            "type": "boolean" },
    { "key": "visible",              "label": "Visible",                "type": "boolean" },
    { "key": "disabled",             "label": "Disabled",               "type": "boolean" },
    { "key": "reset",                "label": "Reset",                  "type": "boolean" },
    { "key": "startYear",            "label": "Start Year",             "type": "number" },
    { "key": "endYear",              "label": "End Year",               "type": "number" },
    { "key": "startOfWeek",          "label": "Start Of Week",          "type": "number" },
    { "key": "OnSelect",             "label": "OnSelect",               "type": "text" },
    { "key": "OnChange",             "label": "OnChange",               "type": "text" }
  ]
}
