{
  "type": "Button",
  "control": "Classic/Button@2.2.0",
  "defaults": {
    "Align": "Align.Center",
    "Text": "\"Button\"",
    "AutoDisableOnSelect": false,
    "BorderColor": "#005a9e",
    "BorderStyle": "BorderStyle.Solid",
    "BorderThickness": 1,
    "Color": "#ffffff",
    "ContentLanguage": "\"en-US\"",
    "DisabledBorderColor": "#a1a1a1",
    "DisabledColor": "#a1a1a1",
    "DisabledFill": "#f3f2f1",
    "DisplayMode": "DisplayMode.Edit",
    "Fill": "#0078d4",
    "FocusedBorderColor": "#0078d4",
    "FocusedBorderThickness": 2,
    "FontWeight": "FontWeight.Semibold",
    "Height": 40,
    "HoverBorderColor": "#004578",
    "HoverColor": "#ffffff",
    "HoverFill": "#005a9e",
    "Italic": false,
    "OnSelect": "Notify(\"Clicked\")",
    "PaddingBottom": 5,
    "PaddingLeft": 10,
    "PaddingRight": 10,
    "PaddingTop": 5,
    "Pressed": false,
    "PressedBorderColor": "#002440",
    "PressedColor": "#ffffff",
    "PressedFill": "#004578",
    "RadiusBottomLeft": 4,
    "RadiusBottomRight": 4,
    "RadiusTopLeft": 4,
    "RadiusTopRight": 4,
    "Size": 14,
    "Underline": false,
    "VerticalAlign": "VerticalAlign.Middle",
    "Visible": true,
    "Width": 160,
    "X": 100,
    "Y": 100
  },
  "properties": [
    { "key": "Text",            "label": "Text",              "type": "text",   "propertyType": "Input" },
    { "key": "OnSelect",        "label": "OnSelect",          "type": "text",    "propertyType": "Event" },
    { "key": "Align",           "label": "Alignment",         "type": "select", "options": ["Align.Left", "Align.Center", "Align.Right", "Align.Justify"], "propertyType": "Input" },
    { "key": "VerticalAlign",    "label": "Vertical Align",    "type": "select", "options": ["VerticalAlign.Top", "VerticalAlign.Middle", "VerticalAlign.Bottom"], "propertyType": "Input" },
    { "key": "X",               "label": "X",                 "type": "number", "propertyType": "Input" },
    { "key": "Y",               "label": "Y",                 "type": "number", "propertyType": "Input" },
    { "key": "Width",           "label": "Width",             "type": "number", "propertyType": "Input" },
    { "key": "Height",          "label": "Height",            "type": "number", "propertyType": "Input" },
    { "key": "Fill",            "label": "Fill",              "type": "color",  "propertyType": "Input" },
    { "key": "Color",           "label": "Text Color",        "type": "color",  "propertyType": "Input" },
    { "key": "Size",            "label": "Font Size",         "type": "number", "propertyType": "Input" },
    { "key": "FontWeight",      "label": "Font Weight",       "type": "select", "options": ["FontWeight.Lighter", "FontWeight.Normal", "FontWeight.Semibold", "FontWeight.Bold"], "propertyType": "Input" },
    { "key": "RadiusTopLeft",   "label": "Radius TL",         "type": "number", "propertyType": "Input" },
    { "key": "RadiusTopRight",  "label": "Radius TR",         "type": "number", "propertyType": "Input" },
    { "key": "RadiusBottomLeft","label": "Radius BL",         "type": "number", "propertyType": "Input" },
    { "key": "RadiusBottomRight","label": "Radius BR",        "type": "number", "propertyType": "Input" },
    { "key": "BorderColor",     "label": "Border Color",      "type": "color",  "propertyType": "Input" },
    { "key": "BorderStyle",     "label": "Border Style",      "type": "select", "options": ["BorderStyle.None", "BorderStyle.Solid", "BorderStyle.Dashed", "BorderStyle.Dotted"], "propertyType": "Input" },
    { "key": "BorderThickness", "label": "Border Width",      "type": "number", "propertyType": "Input" },
    { "key": "HoverFill",       "label": "Hover Fill",        "type": "color",  "propertyType": "Input" },
    { "key": "HoverColor",      "label": "Hover Text Color",   "type": "color",  "propertyType": "Input" },
    { "key": "PressedFill",     "label": "Pressed Fill",      "type": "color",  "propertyType": "Input" },
    { "key": "PressedColor",    "label": "Pressed Text Color", "type": "color",  "propertyType": "Input" },
    { "key": "PaddingTop",      "label": "Padding Top",       "type": "number", "propertyType": "Input" },
    { "key": "PaddingBottom",   "label": "Padding Bottom",    "type": "number", "propertyType": "Input" },
    { "key": "PaddingLeft",     "label": "Padding Left",      "type": "number", "propertyType": "Input" },
    { "key": "PaddingRight",    "label": "Padding Right",     "type": "number", "propertyType": "Input" },
    { "key": "DisplayMode",     "label": "Display Mode",      "type": "select", "options": ["DisplayMode.Edit", "DisplayMode.View", "DisplayMode.Disabled"], "propertyType": "Input" },
    { "key": "Visible",         "label": "Visible",           "type": "boolean", "propertyType": "Input" },
    { "key": "Italic",          "label": "Italic",            "type": "boolean", "propertyType": "Input" },
    { "key": "Underline",       "label": "Underline",         "type": "boolean", "propertyType": "Input" }
  ]
